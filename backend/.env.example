# CraftShield Backend Configuration

# MongoDB connection details
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=craftshield

# JWT Secret key for token signing (use a strong random value in production)
JWT_SECRET=4f9ea4457e5e2e85a6a66699a7776b32812920c57c4ad3d9d300ad89c252277c
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Public frontend URL used inside QR verification links
PUBLIC_APP_URL=http://localhost:5173

# Backend-only HMAC key for verified transaction receipt signatures.
# Never expose this in frontend code, QR payloads, or API responses.
TRANSACTION_PROOF_SECRET=replace-with-a-long-random-secret

# Optional VeChain design provenance settings
VECHAIN_NODE_URL=https://testnet.vechain.org
VECHAIN_CONTRACT_ADDRESS=
VECHAIN_SPONSOR_KEY=
